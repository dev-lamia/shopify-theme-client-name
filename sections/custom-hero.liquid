<section class="custom-hero">
  <div class="page-width">
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.text }}</p>
  </div>
</section>

<style>
  .custom-hero {
    padding: 60px 20px;
    text-align: center;
  }

  .custom-hero h2 {
    font-size: 40px;
    margin-bottom: 16px;
  }

  .custom-hero p {
    font-size: 18px;
  }
</style>

{% schema %}
{
  "name": "Custom Hero",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Welcome to My Store"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "This section was created from VS Code."
    }
  ],
  "presets": [
    {
      "name": "Custom Hero"
    }
  ]
}
{% endschema %}