<section class="custom-hero custom-hero-{{ section.id }}">
  <div class="custom-hero__bg-shape custom-hero__bg-shape--one"></div>
  <div class="custom-hero__bg-shape custom-hero__bg-shape--two"></div>

  <div class="page-width custom-hero__container">
    <div class="custom-hero__content">
      {% if section.settings.badge != blank %}
        <span class="custom-hero__badge">
          {{ section.settings.badge }}
        </span>
      {% endif %}

      <h2>{{ section.settings.heading }}</h2>

      {% if section.settings.text != blank %}
        <p>{{ section.settings.text }}</p>
      {% endif %}

      {% if section.settings.button_text != blank %}
        <a
          class="custom-hero__button"
          href="{{ section.settings.button_link | default: '#' }}"
        >
          {{ section.settings.button_text }}
        </a>
      {% endif %}
    </div>
  </div>
</section>

<style>
  .custom-hero-{{ section.id }} {
    position: relative;
    overflow: hidden;
    padding: 90px 20px;
    text-align: center;
    background:
      radial-gradient(circle at top left, {{ section.settings.accent_color }} 0%, transparent 28%),
      linear-gradient(135deg, {{ section.settings.bg_color_one }}, {{ section.settings.bg_color_two }});
    color: {{ section.settings.text_color }};
  }

  .custom-hero-{{ section.id }} .custom-hero__container {
    position: relative;
    z-index: 2;
  }

  .custom-hero-{{ section.id }} .custom-hero__content {
    max-width: 820px;
    margin: 0 auto;
    padding: 50px 30px;
    border-radius: 28px;
    background: rgba(255, 255, 255, 0.18);
    backdrop-filter: blur(14px);
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.18);
  }

  .custom-hero-{{ section.id }} .custom-hero__badge {
    display: inline-block;
    margin-bottom: 18px;
    padding: 8px 18px;
    border-radius: 999px;
    background: {{ section.settings.badge_color }};
    color: #ffffff;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .custom-hero-{{ section.id }} h2 {
    margin: 0 0 18px;
    font-size: clamp(36px, 6vw, 72px);
    line-height: 1.05;
    font-weight: 800;
    color: {{ section.settings.heading_color }};
  }

  .custom-hero-{{ section.id }} p {
    max-width: 650px;
    margin: 0 auto 30px;
    font-size: clamp(16px, 2vw, 21px);
    line-height: 1.7;
  }

  .custom-hero-{{ section.id }} .custom-hero__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 0 30px;
    border-radius: 999px;
    background: {{ section.settings.button_color }};
    color: #ffffff;
    font-size: 16px;
    font-weight: 700;
    text-decoration: none;
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.22);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .custom-hero-{{ section.id }} .custom-hero__button:hover {
    transform: translateY(-3px);
    box-shadow: 0 18px 45px rgba(0, 0, 0, 0.28);
  }

  .custom-hero-{{ section.id }} .custom-hero__bg-shape {
    position: absolute;
    z-index: 1;
    width: 260px;
    height: 260px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.22);
    filter: blur(4px);
  }

  .custom-hero-{{ section.id }} .custom-hero__bg-shape--one {
    top: -90px;
    left: -80px;
  }

  .custom-hero-{{ section.id }} .custom-hero__bg-shape--two {
    right: -90px;
    bottom: -110px;
  }

  @media screen and (max-width: 749px) {
    .custom-hero-{{ section.id }} {
      padding: 60px 16px;
    }

    .custom-hero-{{ section.id }} .custom-hero__content {
      padding: 36px 22px;
      border-radius: 22px;
    }
  }
</style>

{% schema %}
{
  "name": "Custom Hero",
  "settings": [
    {
      "type": "text",
      "id": "badge",
      "label": "Badge text",
      "default": "New Collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Colorful Shopify Hero"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Build a beautiful Shopify storefront with custom Liquid sections, GitHub version control, and live theme updates."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "bg_color_one",
      "label": "Background color one",
      "default": "#7c3aed"
    },
    {
      "type": "color",
      "id": "bg_color_two",
      "label": "Background color two",
      "default": "#06b6d4"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent glow color",
      "default": "#facc15"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "badge_color",
      "label": "Badge color",
      "default": "#ec4899"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button color",
      "default": "#111827"
    }
  ],
  "presets": [
    {
      "name": "Custom Hero"
    }
  ]
}
{% endschema %}