<style>
.custom-hero-{{ section.id }}{
    position:relative;
    overflow:hidden;
    padding:110px 20px;
    text-align:center;
    isolation:isolate;

    background:linear-gradient(
        -45deg,
        {{ section.settings.bg_color_one }},
        {{ section.settings.bg_color_two }},
        {{ section.settings.accent_color }},
        {{ section.settings.bg_color_one }}
    );

    background-size:400% 400%;
    animation:gradientMove 12s ease infinite;
    color:{{ section.settings.text_color }};
}

@keyframes gradientMove{
    0%{background-position:0% 50%;}
    50%{background-position:100% 50%;}
    100%{background-position:0% 50%;}
}

.custom-hero__container{
    position:relative;
    z-index:5;
}

.custom-hero__content{
    max-width:900px;
    margin:auto;

    padding:65px 50px;

    background:rgba(255,255,255,.15);

    border:1px solid rgba(255,255,255,.2);

    backdrop-filter:blur(22px);

    border-radius:35px;

    box-shadow:
        0 30px 80px rgba(0,0,0,.18),
        inset 0 1px rgba(255,255,255,.35);

    animation:heroFade .9s ease;
}

@keyframes heroFade{

from{

opacity:0;
transform:translateY(40px);

}

to{

opacity:1;
transform:none;

}

}

.custom-hero__badge{

display:inline-block;

padding:10px 22px;

border-radius:999px;

background:{{ section.settings.badge_color }};

color:#fff;

font-weight:700;

font-size:13px;

letter-spacing:2px;

text-transform:uppercase;

margin-bottom:24px;

box-shadow:0 10px 30px rgba(0,0,0,.15);

}

.custom-hero h2,
.custom-hero-{{ section.id }} h2{

font-size:clamp(42px,6vw,78px);

line-height:1.05;

font-weight:900;

margin-bottom:24px;

color:{{ section.settings.heading_color }};

letter-spacing:-2px;

}

.custom-hero p,
.custom-hero-{{ section.id }} p{

font-size:clamp(18px,2vw,22px);

line-height:1.8;

max-width:700px;

margin:0 auto 38px;

opacity:.95;

}

.custom-hero__button{

display:inline-flex;

align-items:center;

justify-content:center;

padding:18px 38px;

border-radius:999px;

font-weight:700;

font-size:16px;

text-decoration:none;

background:{{ section.settings.button_color }};

color:white;

transition:.35s;

box-shadow:

0 15px 35px rgba(0,0,0,.25);

position:relative;

overflow:hidden;

}

.custom-hero__button:before{

content:"";

position:absolute;

left:-120%;

top:0;

width:100%;

height:100%;

background:linear-gradient(

90deg,

transparent,

rgba(255,255,255,.45),

transparent

);

transition:.8s;

}

.custom-hero__button:hover:before{

left:120%;

}

.custom-hero__button:hover{

transform:translateY(-6px) scale(1.05);

box-shadow:

0 22px 45px rgba(0,0,0,.28);

}

.custom-hero__bg-shape{

position:absolute;

border-radius:50%;

filter:blur(25px);

opacity:.35;

animation:floatBlob 8s ease-in-out infinite;

z-index:0;

}

.custom-hero__bg-shape--one{

width:420px;

height:420px;

left:-140px;

top:-120px;

background:#fff;

}

.custom-hero__bg-shape--two{

width:350px;

height:350px;

right:-120px;

bottom:-120px;

background:#fff;

animation-delay:3s;

}

@keyframes floatBlob{

0%{

transform:translateY(0px) scale(1);

}

50%{

transform:translateY(-35px) scale(1.08);

}

100%{

transform:translateY(0px) scale(1);

}

}

/* Decorative Ring */

.custom-hero-{{ section.id }}::before{

content:"";

position:absolute;

width:650px;

height:650px;

border-radius:50%;

border:2px solid rgba(255,255,255,.08);

top:-250px;

right:-200px;

animation:spinRing 28s linear infinite;

}

@keyframes spinRing{

from{

transform:rotate(0deg);

}

to{

transform:rotate(360deg);

}

}

/* Decorative Dots */

.custom-hero-{{ section.id }}::after{

content:"";

position:absolute;

left:8%;

bottom:12%;

width:220px;

height:220px;

background-image:radial-gradient(rgba(255,255,255,.25) 2px,transparent 2px);

background-size:22px 22px;

opacity:.25;

}

@media(max-width:768px){

.custom-hero-{{ section.id }}{

padding:70px 16px;

}

.custom-hero__content{

padding:40px 25px;

border-radius:24px;

}

.custom-hero__button{

width:100%;

}

.custom-hero__bg-shape{

display:none;

}

}
</style>