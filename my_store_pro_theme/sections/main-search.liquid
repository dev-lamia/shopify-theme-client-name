<section class="main-search">
  <div class="page-width">
    <div class="section-heading">
      <span class="eyebrow">Search</span>
      <h2>Search the store</h2>
      <p>Find products, pages and articles quickly.</p>
    </div>

    <form action="{{ routes.search_url }}" method="get" role="search" class="newsletter-form" style="max-width:700px;">
      <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search products" style="color:#111827;background:#fff;border:1px solid var(--color-border);">
      <button class="btn btn--primary" type="submit">Search</button>
    </form>

    {% if search.performed %}
      <div class="product-grid" style="margin-top:44px;">
        {% for item in search.results %}
          {% if item.object_type == 'product' %}
            {% render 'product-card', product: item %}
          {% endif %}
        {% else %}
          <p>No results found.</p>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Main search",
  "settings": []
}
{% endschema %}
