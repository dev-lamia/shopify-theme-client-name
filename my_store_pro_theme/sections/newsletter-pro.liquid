<section class="newsletter-section section-padding">
  <div class="page-width">
    <div class="newsletter-box">
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.text }}</p>

      {% form 'customer', class: 'newsletter-form' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <input
          type="email"
          name="contact[email]"
          value="{{ form.email }}"
          placeholder="Enter your email"
          autocorrect="off"
          autocapitalize="off"
          autocomplete="email"
          required
        >
        <button class="btn btn--light" type="submit">{{ section.settings.button_label }}</button>
        {% if form.posted_successfully? %}
          <p>Thanks for subscribing.</p>
        {% endif %}
      {% endform %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter pro",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Join the VIP list"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Get launch updates, new product alerts and exclusive offers directly in your inbox."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe"
    }
  ],
  "presets": [
    {
      "name": "Newsletter pro"
    }
  ]
}
{% endschema %}
