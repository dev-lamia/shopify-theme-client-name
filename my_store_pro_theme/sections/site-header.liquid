{% if section.settings.announcement != blank %}
  <div class="announcement-bar">
    {{ section.settings.announcement }}
  </div>
{% endif %}

<header class="site-header">
  <div class="page-width site-header__inner">
    <a class="site-logo" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
      <span class="site-logo__mark">{{ shop.name | slice: 0 | upcase }}</span>
      <span>{{ section.settings.logo_text | default: shop.name }}</span>
    </a>

    <nav class="site-nav" aria-label="Main navigation">
      {% for link in linklists.main-menu.links %}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {% else %}
        <a href="{{ routes.root_url }}">Home</a>
        <a href="{{ routes.all_products_collection_url }}">Shop</a>
        <a href="/pages/contact">Contact</a>
      {% endfor %}
    </nav>

    <div class="site-actions">
      <a class="icon-link" href="{{ routes.search_url }}" aria-label="Search">⌕</a>
      <a class="icon-link" href="{{ routes.cart_url }}" aria-label="Cart">🛒</a>
      <button class="menu-toggle" type="button" data-menu-toggle aria-expanded="false" aria-label="Open menu">☰</button>
    </div>
  </div>

  <nav class="mobile-nav" data-mobile-nav aria-label="Mobile navigation">
    {% for link in linklists.main-menu.links %}
      <a href="{{ link.url }}">{{ link.title }}</a>
    {% else %}
      <a href="{{ routes.root_url }}">Home</a>
      <a href="{{ routes.all_products_collection_url }}">Shop</a>
      <a href="/pages/contact">Contact</a>
    {% endfor %}
  </nav>
</header>

{% schema %}
{
  "name": "Site header",
  "settings": [
    {
      "type": "text",
      "id": "announcement",
      "label": "Announcement text",
      "default": "Free shipping on orders over $50 • New arrivals just dropped"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "My Store"
    }
  ]
}
{% endschema %}
