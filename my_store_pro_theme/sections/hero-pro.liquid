<section class="hero-pro">
  <div class="page-width hero-pro__inner">
    <div class="hero-pro__content">
      {% if section.settings.badge != blank %}
        <div class="hero-pro__badge">✨ {{ section.settings.badge }}</div>
      {% endif %}

      <h1>{{ section.settings.heading }}</h1>

      {% if section.settings.text != blank %}
        <p>{{ section.settings.text }}</p>
      {% endif %}

      <div class="hero-pro__actions">
        {% if section.settings.primary_label != blank %}
          <a class="btn btn--light" href="{{ section.settings.primary_link | default: routes.all_products_collection_url }}">
            {{ section.settings.primary_label }}
          </a>
        {% endif %}
        {% if section.settings.secondary_label != blank %}
          <a class="btn btn--outline" href="{{ section.settings.secondary_link | default: '/pages/about' }}">
            {{ section.settings.secondary_label }}
          </a>
        {% endif %}
      </div>

      <div class="hero-pro__stats">
        <div class="hero-pro__stat">
          <strong>{{ section.settings.stat_one_number }}</strong>
          <span>{{ section.settings.stat_one_label }}</span>
        </div>
        <div class="hero-pro__stat">
          <strong>{{ section.settings.stat_two_number }}</strong>
          <span>{{ section.settings.stat_two_label }}</span>
        </div>
        <div class="hero-pro__stat">
          <strong>{{ section.settings.stat_three_number }}</strong>
          <span>{{ section.settings.stat_three_label }}</span>
        </div>
      </div>
    </div>

    <div class="hero-pro__visual">
      <span class="float-pill float-pill--one">Fast delivery</span>
      <span class="float-pill float-pill--two">Premium quality</span>
      <div class="hero-pro__card">
        <div class="hero-pro__mock-image">
          {% if section.settings.hero_image != blank %}
            {{ section.settings.hero_image | image_url: width: 900 | image_tag: loading: 'eager', alt: section.settings.heading }}
          {% else %}
            🛍️
          {% endif %}
        </div>
        <div class="hero-pro__mock-footer">
          <div>
            <strong>{{ section.settings.product_title }}</strong><br>
            <span>{{ section.settings.product_subtitle }}</span>
          </div>
          <a class="btn btn--primary" href="{{ section.settings.primary_link | default: routes.all_products_collection_url }}">View</a>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Professional hero",
  "settings": [
    {
      "type": "text",
      "id": "badge",
      "label": "Badge",
      "default": "Limited time collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Make your store look premium"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "default": "A modern, colorful and conversion-focused Shopify homepage built with Liquid sections, responsive design and clean code."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Shop collection"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Explore story"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "product_title",
      "label": "Card title",
      "default": "Signature Product"
    },
    {
      "type": "text",
      "id": "product_subtitle",
      "label": "Card subtitle",
      "default": "Best seller"
    },
    {
      "type": "text",
      "id": "stat_one_number",
      "label": "Stat one number",
      "default": "25k+"
    },
    {
      "type": "text",
      "id": "stat_one_label",
      "label": "Stat one label",
      "default": "Happy customers"
    },
    {
      "type": "text",
      "id": "stat_two_number",
      "label": "Stat two number",
      "default": "4.9★"
    },
    {
      "type": "text",
      "id": "stat_two_label",
      "label": "Stat two label",
      "default": "Average rating"
    },
    {
      "type": "text",
      "id": "stat_three_number",
      "label": "Stat three number",
      "default": "48h"
    },
    {
      "type": "text",
      "id": "stat_three_label",
      "label": "Stat three label",
      "default": "Fast dispatch"
    }
  ],
  "presets": [
    {
      "name": "Professional hero"
    }
  ]
}
{% endschema %}
