<section class="section-padding" style="background: {{ section.settings.background }};">
  <div class="page-width">
    <div class="section-heading">
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.text }}</p>
    </div>

    <div class="product-grid">
      {% assign selected_collection = section.settings.collection %}
      {% if selected_collection != blank and selected_collection.products_count > 0 %}
        {% for product in selected_collection.products limit: section.settings.product_limit %}
          {% render 'product-card', product: product %}
        {% endfor %}
      {% else %}
        {% for i in (1..4) %}
          <article class="product-card">
            <div class="product-card__media">
              <span class="product-card__placeholder">🛍️</span>
            </div>
            <div class="product-card__body">
              <h3 class="product-card__title">Premium Product {{ i }}</h3>
              <div class="product-card__price">$49.00</div>
            </div>
          </article>
        {% endfor %}
      {% endif %}
    </div>

    {% if section.settings.button_label != blank %}
      <div style="text-align:center;margin-top:34px;">
        <a class="btn btn--primary" href="{{ selected_collection.url | default: routes.all_products_collection_url }}">
          {{ section.settings.button_label }}
        </a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Featured products",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Best sellers"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Products your customers will love"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Showcase your strongest products with clean cards, pricing and premium spacing."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "product_limit",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "View all products"
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background",
      "default": "#f7f7fb"
    }
  ],
  "presets": [
    {
      "name": "Featured products"
    }
  ]
}
{% endschema %}
