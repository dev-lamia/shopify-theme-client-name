<section class="section-padding">
  <div class="page-width">
    <div class="collection-banner">
      <div class="collection-banner__content">
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        <h2>{{ section.settings.heading }}</h2>
        <p>{{ section.settings.text }}</p>
        <a class="btn btn--primary" href="{{ section.settings.button_link | default: routes.all_products_collection_url }}">
          {{ section.settings.button_label }}
        </a>
      </div>
      <div class="collection-banner__visual">
        {% if section.settings.image != blank %}
          {{ section.settings.image | image_url: width: 900 | image_tag: loading: 'lazy', alt: section.settings.heading }}
        {% else %}
          <div class="collection-banner__bubble">✨</div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection banner",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "New season"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Launch a homepage that feels like a real brand"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Use this section for a campaign, featured category, special offer or seasonal promotion."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Explore collection"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    }
  ],
  "presets": [
    {
      "name": "Collection banner"
    }
  ]
}
{% endschema %}
